{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["cache", "imgproxy", "ingress", "origin"],
  "properties": {
    "cache": {
      "type": "object",
      "required": ["image", "replicas", "service"],
      "properties": {
        "replicas": {
          "type": "integer",
          "minimum": 1
        },
        "image": {
          "type": "object",
          "required": ["digest", "repository"],
          "properties": {
            "digest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            },
            "repository": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "service": {
          "type": "object",
          "required": ["port"],
          "properties": {
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "required": ["hosts"],
      "properties": {
        "hosts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

